  "dialogue_blocks": [
    {
      "speaker": "Isabel",
      "text": "¿Cómo es tu apartamento?",
      "translation": "What is your apartment like?",
      "ipa": "[ˈkomo es tu apaɾtaˈmento]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-001",
      "alternate_phrasing": [],
      "context": "Asking about home"
    },
    {
      "speaker": "Andrés",
      "text": "Es pequeño pero muy cómodo. Tiene sala, cocina, dos recámaras y un baño.",
      "translation": "It's small but very comfortable. It has a living room, kitchen, two bedrooms and one bathroom.",
      "ipa": "[es peˈkeɲo ˈpeɾo muj ˈkomoðo]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-002",
      "alternate_phrasing": [],
      "context": "Describing apartment"
    },
    {
      "speaker": "Isabel",
      "text": "¿En qué piso vives?",
      "translation": "What floor do you live on?",
      "ipa": "[en ke ˈpiso ˈβiβes]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-003",
      "alternate_phrasing": [],
      "context": "Asking floor"
    },
    {
      "speaker": "Andrés",
      "text": "En el quinto piso. No hay elevador, así que subo las escaleras todos los días.",
      "translation": "On the fifth floor. There's no elevator, so I take the stairs every day.",
      "ipa": "[en el ˈkinto ˈpiso ‖ no aj eleβaˈðoɾ]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-004",
      "alternate_phrasing": [],
      "context": "Describing floor and stairs"
    },
    {
      "speaker": "Isabel",
      "text": "¿Qué muebles tienes en la sala?",
      "translation": "What furniture do you have in the living room?",
      "ipa": "[ke ˈmweβles ˈtjenes en la ˈsala]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-005",
      "alternate_phrasing": [],
      "context": "Asking about furniture"
    },
    {
      "speaker": "Andrés",
      "text": "Tengo un sofá, una mesa de centro y un librero lleno de libros.",
      "translation": "I have a sofa, a coffee table and a bookshelf full of books.",
      "ipa": "[ˈteŋɡo un soˈfa ‖ ˈuna ˈmesa ðe ˈθentɾo i un liˈβɾeɾo]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-006",
      "alternate_phrasing": [],
      "context": "Describing living room"
    },
    {
      "speaker": "Isabel",
      "text": "¿Pagas mucho de renta?",
      "translation": "Do you pay a lot in rent?",
      "ipa": "[ˈpaɣas ˈmuʧo ðe ˈɾenta]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-007",
      "alternate_phrasing": [],
      "context": "Asking about rent"
    },
    {
      "speaker": "Andrés",
      "text": "Sí, pero incluye agua y gas. Vale la pena por la ubicación.",
      "translation": "Yes, but it includes water and gas. It's worth it for the location.",
      "ipa": "[si ‖ ˈpeɾo iŋˈkluje ˈaɣwa i ˈɡas ‖ ˈβale la ˈpena]",
      "dialect": "es-MX",
      "audio_asset_id": "a2-home-mx-008",
      "alternate_phrasing": [],
      "context": "Discussing value of rent"
    }
  ],
